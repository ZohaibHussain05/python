for n in [6, 8]:
    print(f"\n{'='*40}")
    print(f" N = {n}")
    print(f"{'='*40}")

    solution, restarts = random_restart_hc(n)

    if solution is not None:
        print_hall(solution)
        print(f"Conflicts    : {conflicts(solution)}")
        print(f"Restarts used: {restarts}")
    else:
        print(f"No solution found within {restarts} restarts.")






