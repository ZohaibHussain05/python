import numpy as np

# 1. Create arrays
problems = np.array([5, 7, 4, 7, 6, 3, 5], dtype=np.int64 )
penalty  = np.array([120, 85, 145, 90, 110, 160, 130], dtype=np.int64)

# 2. Compute mean, max, min of Problems Solved
fmt = lambda v: f"{v:.2f}" if v is not None else "None"

mean_problems = np.mean(problems)
max_problems  = np.max(problems)
min_problems  = np.min(problems)

print(f"Mean Problems Solved : {fmt(mean_problems)}")
print(f"Max  Problems Solved : {max_problems}")
print(f"Min  Problems Solved : {min_problems}")

# 3. Boolean indexing — penalty times of above-mean solvers
