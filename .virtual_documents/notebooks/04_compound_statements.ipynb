def absolute_value(x):
    """Compute abs(x)."""
    if x > 0:
        return x
    elif x == 0:
        return 0
    else:
        return -x


def absolute_value(x):
    """Compute abs(x)."""
    if not x < 0:
        return x
    else:
        return -x


